# ===== Vision model (multimodal) =====
# Any OpenAI-compatible /v1 multimodal endpoint works.
# Examples below. BaseURL should end with /v1 (do NOT include /chat/completions).

# Aliyun DashScope (qwen-vl series)
VISION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VISION_API_KEY=sk-your-vision-key
VISION_MODEL=qwen3.7-plus

# OpenAI (uncomment to switch)
# VISION_BASE_URL=https://api.openai.com/v1
# VISION_API_KEY=sk-xxx
# VISION_MODEL=gpt-4o

# Local Ollama running llava (uncomment to switch)
# VISION_BASE_URL=http://localhost:11434/v1
# VISION_API_KEY=ollama
# VISION_MODEL=llava:13b

# ===== Optional =====
# Per-request timeout in seconds (vision calls can be slow on big images).
REQUEST_TIMEOUT=120

# NOTE: there is intentionally NO "reason model" config here.
# The main reasoning model is whatever you selected in your MCP client
# (glm-5.2, deepseek-v4-pro, qwen-text, ...). This server only converts images
# to text; the reasoning is done by your session's main model.
